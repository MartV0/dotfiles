# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
name = MartV0
email = martijnvoordouw@gmail.com
	signingkey = /home/martijn/.ssh/id_ed25519.pub
[pull]
	; rebase = false
	rebase = true
[commit]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers_git
[init]
	defaultBranch = main
